{
  "manifest_version": 3,
  "name": "New Tab Dashboard",
  "version": "0.1.0",
  "description": "A minimal productivity dashboard for your new tab.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
